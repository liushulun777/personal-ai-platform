server:
  port: 1085

spring:
  application:
    name: search-service
  datasource:
    driver-class-name: org.postgresql.Driver
    url: jdbc:postgresql://172.18.0.34:5432/platform
    username: postgres
    password: postgres
    druid:
      initial-size: 5
      min-idle: 5
      max-active: 20
  data:
    redis:
      host: 172.18.0.34
      port: 6379
      database: 0
    elasticsearch:
      uris: http://172.18.0.34:9200
  cloud:
    nacos:
      discovery:
        server-addr: 172.18.0.34:8848
        fail-fast: false
  kafka:
    bootstrap-servers: 172.18.0.34:29092
    # consumer 配置已移至 KafkaConfig.java 编程式配置

mybatis-plus:
  mapper-locations: classpath*:/mapper/**/*.xml
  configuration:
    map-underscore-to-camel-case: true
  global-config:
    db-config:
      id-type: ASSIGN_ID
      logic-delete-field: deleted
      logic-delete-value: 1
      logic-not-delete-value: 0

sa-token:
  token-name: Authorization
  timeout: 86400
  is-read-header: true
  is-read-cookie: false

# AI 模型配置（用于向量嵌入）
ai:
  models:
    embedding-provider: ollama
    config:
      ollama:
        base-url: http://192.168.9.95:11434
        model: nomic-embed-text
        api-key: ''

# 搜索服务专用配置
search:
  chunk:
    size: 500
    overlap: 50
  embedding:
    top-k: 20

logging:
  level:
    com.platform.search: debug
    org.springframework.data.elasticsearch: debug
